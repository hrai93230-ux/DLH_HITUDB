<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DLH_HITU SIM DB </title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://kommodo.ai/i/TOVXyNoowOsQ1sKJX8Nf">

    <style>
        :root {
            --primary: #00d4ff;
            --primary-glow: rgba(0, 212, 255, 0.4);
            --secondary: #7c3aed;
            --accent: #f472b6;
            --dark: #0a0a0f;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-highlight: rgba(255, 255, 255, 0.15);
            --text-primary: #ffffff;
            --text-secondary: rgba(255, 255, 255, 0.6);
            --error: #ef4444;
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--dark);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .bg-animation::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(circle at 20% 80%, rgba(0, 212, 255, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(124, 58, 237, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, rgba(244, 114, 182, 0.1) 0%, transparent 40%);
            animation: bgMove 20s ease-in-out infinite;
        }

        .bg-animation::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            backdrop-filter: blur(100px);
            background: rgba(10, 10, 15, 0.7);
        }

        @keyframes bgMove {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }

        /* Noise Texture Overlay */
        .noise {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0.03;
            z-index: -1;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            pointer-events: none;
        }

        /* Glass Container */
        .glass-container {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            box-shadow: 
                0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 var(--glass-highlight);
        }

        /* Header */
        header {
            padding: 24px 20px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 10, 15, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: 3px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .logo i {
            font-size: 32px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Startup Popup */
        #popupOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(10px);
            opacity: 1;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }

        #popupOverlay.hidden {
            opacity: 0;
            visibility: hidden;
        }

        .popup-card {
            background: linear-gradient(145deg, rgba(30, 30, 40, 0.9), rgba(20, 20, 30, 0.95));
            padding: 40px 32px;
            border-radius: 24px;
            text-align: center;
            border: 1px solid var(--glass-border);
            max-width: 380px;
            width: 90%;
            box-shadow: 
                0 25px 50px -12px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(255, 255, 255, 0.05),
                inset 0 1px 0 rgba(255, 255, 255, 0.1);
            transform: scale(0.9) translateY(20px);
            opacity: 0;
            animation: popupEnter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @keyframes popupEnter {
            to {
                transform: scale(1) translateY(0);
                opacity: 1;
            }
        }

        .popup-card h2 {
            margin: 0 0 12px 0;
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .popup-card p {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 28px;
            line-height: 1.6;
        }

        .popup-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 14px 20px;
            margin: 10px 0;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow: hidden;
        }

        .popup-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .popup-btn:hover::before {
            left: 100%;
        }

        .btn-wa { 
            background: linear-gradient(135deg, #25d366 0%, #128c7e 100%); 
            color: white; 
            text-decoration: none;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }

        .btn-wa:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
        }

        .btn-web { 
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); 
            color: white;
            box-shadow: 0 4px 15px var(--primary-glow);
        }

        .btn-web:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px var(--primary-glow);
        }

        /* Main Content */
        .container {
            flex: 1;
            padding: 40px 20px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        .search-box {
            padding: 40px;
            border-radius: 24px;
            position: relative;
            overflow: hidden;
        }

        .search-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            opacity: 0.5;
        }

        .search-header {
            text-align: center;
            margin-bottom: 28px;
        }

        .search-header h3 {
            font-size: 22px;
            font-weight: 700;
            margin: 0 0 8px 0;
            letter-spacing: 0.5px;
        }

        .search-header p {
            color: var(--text-secondary);
            font-size: 13px;
            margin: 0;
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 18px;
            transition: color 0.3s;
        }

        input:focus + .input-icon,
        input:not(:placeholder-shown) + .input-icon {
            color: var(--primary);
        }

        input {
            width: 100%;
            padding: 18px 18px 18px 52px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            color: var(--text-primary);
            font-size: 16px;
            font-weight: 500;
            outline: none;
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.3s ease;
        }

        input::placeholder {
            color: var(--text-secondary);
            font-family: 'Inter', sans-serif;
            font-weight: 400;
        }

        input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-glow), inset 0 1px 0 rgba(255,255,255,0.1);
            background: rgba(0, 0, 0, 0.4);
        }

        .search-btn {
            width: 100%;
            padding: 18px 24px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            border: none;
            border-radius: 14px;
            color: white;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 20px rgba(0, 212, 255, 0.3);
        }

        .search-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s;
        }

        .search-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 212, 255, 0.4);
        }

        .search-btn:hover::before {
            left: 100%;
        }

        .search-btn:active {
            transform: translateY(0);
        }

        /* Modern Database Loader */
        .loader {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 40px 0;
            gap: 20px;
        }

        .loader.active {
            display: flex;
        }

        .database-loader {
            position: relative;
            width: 80px;
            height: 80px;
        }

        .loader-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 3px solid transparent;
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1.5s linear infinite;
        }

        .loader-ring:nth-child(2) {
            width: 70%;
            height: 70%;
            top: 15%;
            left: 15%;
            border-top-color: var(--secondary);
            animation-duration: 1s;
            animation-direction: reverse;
        }

        .loader-ring:nth-child(3) {
            width: 40%;
            height: 40%;
            top: 30%;
            left: 30%;
            border-top-color: var(--accent);
            animation-duration: 0.8s;
        }

        .loader-core {
            position: absolute;
            width: 20%;
            height: 20%;
            top: 40%;
            left: 40%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 50%;
            animation: pulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 20px var(--primary-glow);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(0.8); opacity: 0.7; }
        }

        .loader-text {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            animation: textPulse 1.5s ease-in-out infinite;
        }

        @keyframes textPulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        .loader-dots {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }

        .loader-dot {
            width: 6px;
            height: 6px;
            background: var(--primary);
            border-radius: 50%;
            animation: dotBounce 1.4s ease-in-out infinite both;
        }

        .loader-dot:nth-child(1) { animation-delay: -0.32s; }
        .loader-dot:nth-child(2) { animation-delay: -0.16s; }

        @keyframes dotBounce {
            0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
            40% { transform: scale(1); opacity: 1; }
        }

        /* Data Cards */
        #results { 
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .data-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            padding: 28px;
            border-radius: 20px;
            border-left: 4px solid var(--primary);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            animation: cardEnter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            opacity: 0;
            transform: translateY(20px);
            position: relative;
            overflow: hidden;
        }

        .data-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, var(--primary), transparent);
            opacity: 0.5;
        }

        @keyframes cardEnter {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .data-card:hover { 
            transform: translateY(-4px) scale(1.01);
            border-color: var(--glass-highlight);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(0, 212, 255, 0.1);
        }

        .data-card.error {
            border-left-color: var(--error);
            text-align: center;
        }

        .data-card.error::before {
            background: linear-gradient(90deg, var(--error), transparent);
        }

        .card-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .card-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .card-item.full-width {
            grid-column: span 2;
        }

        .label { 
            font-size: 11px; 
            color: var(--primary); 
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .value { 
            font-size: 16px; 
            font-weight: 600;
            color: var(--text-primary);
            word-break: break-word;
            font-family: 'JetBrains Mono', monospace;
        }

        .value.name {
            font-family: 'Inter', sans-serif;
            font-size: 18px;
            font-weight: 700;
        }

        .value i {
            color: var(--primary);
            margin-right: 4px;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 30px 20px;
            margin-top: auto;
            border-top: 1px solid var(--glass-border);
            background: rgba(0, 0, 0, 0.2);
        }

        .social-icons {
            display: flex;
            justify-content: center;
            gap: 24px;
            margin-bottom: 16px;
        }

        .social-icons a {
            color: var(--text-secondary);
            font-size: 24px;
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
        }

        .social-icons a:hover { 
            color: var(--primary);
            border-color: var(--primary);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 212, 255, 0.2);
        }

        footer p {
            font-size: 12px; 
            color: var(--text-secondary);
            margin: 0;
            letter-spacing: 0.5px;
        }

        /* Mobile Responsive */
        @media (max-width: 600px) {
            .logo {
                font-size: 22px;
                letter-spacing: 2px;
            }

            .logo i {
                font-size: 26px;
            }

            .container {
                padding: 24px 16px;
            }

            .search-box {
                padding: 28px 24px;
            }

            .search-header h3 {
                font-size: 18px;
            }

            .popup-card {
                padding: 32px 24px;
            }

            .card-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }

            .card-item.full-width {
                grid-column: span 1;
            }

            .data-card {
                padding: 22px;
            }

            .value {
                font-size: 14px;
            }

            .value.name {
                font-size: 16px;
            }
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--glass-border);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--glass-highlight);
        }
    </style>
<script>(function(){var n=function(){};['log','warn','error','info','debug','dir','trace','table','group','groupEnd','time','timeEnd','assert','count','clear'].forEach(function(k){try{window.console[k]=n;}catch(e){}});})();</script></head>
<body>
    <div class="bg-animation"></div>
    <div class="noise"></div>

    <!-- Startup Popup -->
    <div id="popupOverlay">
        <div class="popup-card">
            <i class="fas fa-shield-alt" style="font-size: 48px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 16px;"></i>
            <h2>Welcome to Our Database</h2>
            <p>Join our official channels for latest updates, security alerts, and exclusive tools.</p>
            <a href="https://whatsapp.com/channel/0029VbBkW1o05MUefnHEXC2i" target="_blank" class="popup-btn btn-wa">
                <i class="fab fa-whatsapp"></i> Join WhatsApp Channel
            </a>
            <button onclick="closePopup()" class="popup-btn btn-web">
                <i class="fas fa-globe"></i> Continue to Website
            </button>
        </div>
    </div>

    <header>
        <div class="logo">
            <i class="fas fa-database"></i>
            DLH_HITU SIM Database
        </div>
    </header>

    <div class="container">
        <div class="search-box glass-container">
            <div class="search-header">
                <h3>Database Search</h3>
                <p>Enter CNIC or Mobile Number to retrieve records</p>
            </div>

            <div class="input-wrapper">
                <input type="number" id="numInput" placeholder="Enter CNIC or Mobile (e.g 3368443729)">
                <i class="fas fa-search input-icon"></i>
            </div>

            <button class="search-btn" onclick="fetchData()">
                <i class="fas fa-search"></i> Find Information
            </button>
        </div>

        <div class="loader" id="loader">
            <div class="database-loader">
                <div class="loader-ring"></div>
                <div class="loader-ring"></div>
                <div class="loader-ring"></div>
                <div class="loader-core"></div>
            </div>
            <div class="loader-text">Searching DLH_HITU Database</div>
            <div class="loader-dots">
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
            </div>
        </div>

        <div id="results"></div>
    </div>

    <footer>
        <div class="social-icons">
            <a href="https://wa.me/+923368443729" target="_blank" title="WhatsApp">
                <i class="fab fa-whatsapp"></i>
            </a>
            <a href="DLH_HITU" target="_blank" title="Telegram">
                <i class="fab fa-telegram"></i>
            </a>
        </div>
        <p>&copy; 2026 DLH_HITU HACKS. All Rights Reserved.</p>
    </footer>

    <script>
        // Popup function
        function closePopup() {
            const popup = document.getElementById('popupOverlay');
            popup.classList.add('hidden');
            setTimeout(() => {
                popup.style.display = 'none';
            }, 400);
        }

        async function fetchData() {
            const num = document.getElementById('numInput').value;
            const resultsDiv = document.getElementById('results');
            const loader = document.getElementById('loader');

            if (!num) {
                alert("Please enter a number first!");
                return;
            }

            // 
            resultsDiv.innerHTML = "";
            loader.classList.add('active');

            try {
                const response = await fetch(`https://ftgm-simdb-api.vercel.app?num=${num}`);
                const data = await response.json();

                loader.classList.remove('active');

                if (data.ok && data.records.length > 0) {
                    data.records.forEach((record, index) => {
                        const card = document.createElement('div');
                        card.className = 'data-card';
                        card.style.animationDelay = `${index * 0.1}s`;
                        card.innerHTML = `
                            <div class="card-grid">
                                <div class="card-item">
                                    <span class="label"><i class="fas fa-user"></i> Name</span>
                                    <span class="value name">${record.name || 'N/A'}</span>
                                </div>
                                <div class="card-item">
                                    <span class="label"><i class="fas fa-mobile-alt"></i> Mobile</span>
                                    <span class="value">${record.mobile}</span>
                                </div>
                                <div class="card-item full-width">
                                    <span class="label"><i class="fas fa-id-card"></i> CNIC</span>
                                    <span class="value">${record.cnic}</span>
                                </div>
                                <div class="card-item full-width">
                                    <span class="label"><i class="fas fa-map-marker-alt"></i> Address</span>
                                    <span class="value">${record.address || 'Not Available'}</span>
                                </div>
                                <div class="card-item">
                                    <span class="label"><i class="fas fa-signal"></i> Operator</span>
                                    <span class="value"><i class="fas fa-broadcast-tower"></i> ${record.operator}</span>
                                </div>
                            </div>
                        `;
                        resultsDiv.appendChild(card);
                    });
                } else {
                    const errorCard = document.createElement('div');
                    errorCard.className = 'data-card error';
                    errorCard.innerHTML = `
                        <i class="fas fa-exclamation-circle" style="font-size: 32px; color: var(--error); margin-bottom: 12px;"></i>
                        <div style="font-weight: 600; font-size: 16px;">No Records Found</div>
                        <div style="color: var(--text-secondary); font-size: 13px; margin-top: 4px;">Invalid Input or No Data Available</div>
                    `;
                    resultsDiv.appendChild(errorCard);
                }
            } catch (error) {
                loader.classList.remove('active');
                const errorCard = document.createElement('div');
                errorCard.className = 'data-card error';
                errorCard.innerHTML = `
                    <i class="fas fa-wifi" style="font-size: 32px; color: var(--error); margin-bottom: 12px;"></i>
                    <div style="font-weight: 600; font-size: 16px;">Data Not Found</div>
                    <div style="color: var(--text-secondary); font-size: 13px; margin-top: 4px;">I Think This Number Is Registered After 2022 So The Data Is Not In Our Database. Join Whatsapp For More Updates</div>
                `;
                resultsDiv.appendChild(errorCard);
            }
        }

        // Enter key support
        document.getElementById('numInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                fetchData();
            }
        });
    </script>
<script>document.addEventListener('contextmenu',function(e){e.preventDefault();return false;});</script><script>document.addEventListener('keydown',function(e){var b=[123];if(e.ctrlKey&&e.shiftKey)b.push(73,74,67);if(e.ctrlKey)b.push(85,83,65,80,86);if(b.indexOf(e.keyCode)>-1){e.preventDefault();return false;}});</script><script>(function(){
if(window.self!==window.top)return;
var _b=false;
function _chk(){
  var _dw=window.outerWidth-window.innerWidth;
  var _dh=window.outerHeight-window.innerHeight;
  if(_dw>200||_dh>200){
    if(!_b){_b=true;
      document.body.style.cssText='margin:0;display:flex;align-items:center;justify-content:center;height:100vh;background:#050A15;';
      document.body.innerHTML='<div style="text-align:center;color:#FF3B30;font-family:monospace;"><i class="fa-solid fa-ban" style="font-size:64px;margin-bottom:16px;filter:drop-shadow(0 0 15px rgba(255,59,48,0.5));"></i><div style="font-size:22px;letter-spacing:3px;font-weight:bold;">DEVTOOLS BLOCKED</div></div>';
    }
  }else{_b=false;}
}
setInterval(_chk,1000);
})();</script></body>
</html>
